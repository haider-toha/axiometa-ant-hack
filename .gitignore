# Local CAD / temp artifacts
*.stl.tmp
*.step.tmp

# Slide deck build directory.
# The generic `build/` rule above (intended for Node dist output) also matches
# slides/build/, which would drop the two pipeline scripts. Re-include the
# directory, then re-exclude only the regenerable heavy artifacts:
#   mesh/*.stl        46 MB — regenerate: .venv/bin/python slides/build/step_to_stl.py
#   *.blend           19 MB — 3 min re-render, and the frames it produces are committed
!slides/build/
slides/build/mesh/
slides/build/*.blend
slides/build/*.blend[0-9]*

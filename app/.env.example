# Upstash Redis — the device relay state. Both are required by Redis.fromEnv().
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# Modal detector endpoint the phone POSTs frames to. NEXT_PUBLIC_ so the
# in-browser capture page can read it (or pass ?modal=<url> on the page URL).
NEXT_PUBLIC_MODAL_URL=""

# Production relay: https://tacta.space

# REQUIRED on Vercel — used at request time by /api/person-direction to ask
# Claude which side of a person / obstacle has clear pavement. Without this the
# route degrades to a constant "ahead" and the wearer receives no route-around
# instruction. The bus-blind OCR path also runs against Claude but from Modal,
# not from the web app, so this key is needed even if Modal is fully configured.
ANTHROPIC_API_KEY=""

# Upstash Redis — the device relay state. Both are required by Redis.fromEnv().
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# Modal detector endpoint the phone POSTs frames to. NEXT_PUBLIC_ so the
# in-browser capture page can read it (or pass ?modal=<url> on the page URL).
NEXT_PUBLIC_MODAL_URL=""

# Only needed if you run Claude locally. Claude normally runs inside Modal,
# so the web app does not use this key at runtime.
ANTHROPIC_API_KEY=""
